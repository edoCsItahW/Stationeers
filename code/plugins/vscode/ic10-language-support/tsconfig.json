{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2024",
        "lib": ["es2024"],
        "outDir": "out",
        "rootDir": "src",
        "sourceMap": true,
        "types": ["node", "vscode"],
        "allowArbitraryExtensions": true,
        "moduleResolution": "NodeNext",
        "esModuleInterop": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ],
    "references": [
        { "path": "./client" },
        { "path": "./server" }
    ]
}
